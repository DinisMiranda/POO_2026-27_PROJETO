# Opcional — a app base funciona sem este ficheiro.
# Copiar para .env na raiz apenas se usares o assistente Ollama (npm run chat-api).

# URL do servidor Ollama local
OLLAMA_URL=http://localhost:11434

# Modelo instalado com: ollama pull llama3.2
OLLAMA_MODEL=llama3.2

# Porta do servidor de chat Zenify (server/chat-api.js)
CHAT_API_PORT=3002
